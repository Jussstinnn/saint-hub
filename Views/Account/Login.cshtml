@{
    ViewData["Title"] = "Iniciar sesión";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Account.css" asp-append-version="true" />
}

<div class="account-wrapper">

    <div class="account-card">

        <!-- HEADER -->
        <div class="account-head">
            <h1>Bienvenido</h1>
            <p>Iniciá sesión para continuar en Saint Hub</p>
        </div>

        <!-- LOGIN FORM -->
        <form asp-controller="Account"
              asp-action="Login"
              method="post"
              class="account-form">

            @Html.AntiForgeryToken()

            <div class="field">
                <label>Correo electrónico</label>
                <input type="email"
                       name="email"
                       placeholder="correo@ejemplo.com"
                       required />
            </div>

            <div class="field">
                <label>Contraseña</label>
                <input type="password"
                       name="password"
                       placeholder="••••••••"
                       required />
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="account-error">
                    @ViewBag.Error
                </div>
            }

            <button type="submit" class="btn-account-primary">
                Iniciar sesión
            </button>
        </form>

        <!-- DIVIDER -->
        <div class="account-divider">
            <span>o</span>
        </div>

        <!-- GOOGLE LOGIN -->
        <a asp-controller="Account"
           asp-action="GoogleLogin"
           class="btn-account-outline">
            Continuar con Google
        </a>

        <!-- FOOT -->
        <div class="account-foot">
            <span>¿No tenés cuenta?</span>
            <a asp-controller="Account" asp-action="Register">Crear cuenta</a>
        </div>

        <div class="account-foot secondary">
            <a asp-controller="Account" asp-action="ForgotPassword">
                ¿Olvidaste tu contraseña?
            </a>
        </div>

    </div>

</div>
