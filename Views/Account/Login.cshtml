@{
    ViewData["Title"] = "Iniciar sesión";
}

<div style="display:flex; justify-content:center; margin-top:4rem;">
    <div class="card-saint" style="max-width:420px; width:100%;">

        <h1 style="text-align:center;">Bienvenido</h1>
        <p style="text-align:center; color:var(--text-muted); margin-bottom:1.5rem;">
            Iniciá sesión para continuar en Saint Hub
        </p>

        <form method="post">
            <input class="input-saint"
                   type="email"
                   name="email"
                   placeholder="Correo electrónico"
                   required />

            <input class="input-saint"
                   type="password"
                   name="password"
                   placeholder="Contraseña"
                   required
                   style="margin-top:.8rem;" />

            @if (ViewBag.Error != null)
            {
                <p style="color:var(--danger); margin-top:.6rem;">
                    @ViewBag.Error
                </p>
            }

            <button class="btn-saint"
                    style="margin-top:1.2rem; width:100%;">
                Entrar
            </button>
        </form>

        <div style="text-align:center; margin-top:1.5rem;">
            <small style="color:var(--text-muted);">
                ¿No tenés cuenta?
            </small><br />
            <a asp-action="Register"
               style="color:var(--accent); text-decoration:none; font-weight:700;">
                Crear cuenta
            </a>
        </div>

    </div>
</div>

