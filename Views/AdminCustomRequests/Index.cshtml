@model List<SaintHub.Models.CustomRequest>

<h1>Pedidos personalizados</h1>
<p class="text-muted">
    Solicitudes recibidas por encargo y pedidos especiales
</p>

@if (!Model.Any())
{
    <div class="card-saint" style="margin-top:2rem;">
        <p>No hay solicitudes registradas.</p>
    </div>
}
else
{
    <div class="card-saint" style="margin-top:2rem;">
        <table class="table-saint admin-table">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Contacto</th>
                    <th>Pedido</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <strong>@(string.IsNullOrWhiteSpace(r.FullName) ? "—" : r.FullName)</strong>
                        </td>

                        <td>
                            <small>
                                @(string.IsNullOrWhiteSpace(r.Email) ? "Sin email" : r.Email)<br />
                                @(string.IsNullOrWhiteSpace(r.Phone) ? "Sin teléfono" : r.Phone)
                            </small>
                        </td>

                        <td>
                            <small>
                                @(string.IsNullOrWhiteSpace(r.RequestType) ? "Pedido personalizado" : r.RequestType)<br />
                                @(string.IsNullOrWhiteSpace(r.Brand) ? "Marca no indicada" : r.Brand)
                                @(string.IsNullOrWhiteSpace(r.Model) ? "" : r.Model)<br />
                                Talla: @(string.IsNullOrWhiteSpace(r.Size) ? "—" : r.Size)
                            </small>
                        </td>

                        <td>
                            <span class="status-pill status-@r.Status.ToLower()">
                                @r.Status
                            </span>
                        </td>

                        <td>
                            <small>@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                        </td>

                        <td>
                            <a asp-action="Details"
                               asp-route-id="@r.Id"
                               class="btn-saint-outline btn-sm">
                                Ver
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}





