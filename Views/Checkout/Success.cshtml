@model SaintHub.Models.Order
@{
    var items = ViewBag.Items as List<SaintHub.Models.OrderItem>;
}

<div class="success-wrapper">
    <div class="success-card">

        <div class="success-icon">✔</div>

        <h1>¡Pedido recibido!</h1>
        <p class="success-subtitle">
            Gracias por comprar en <strong>Saint Hub</strong>.
            Tu pedido fue registrado correctamente.
        </p>

        <div class="order-info">
            <div><span>Pedido</span> <strong>#@Model.Id</strong></div>
            <div>
                <span>Estado</span>
                <span class="badge badge-pending">@Model.Status</span>
            </div>
            <div><span>Total</span> <strong>₡ @Model.TotalCrc.ToString("N0")</strong></div>
        </div>

        <hr />

        <h3>Resumen</h3>
        @foreach (var i in items!)
        {
            <div class="order-item">
                <span>@i.ProductName (@i.Option) × @i.Quantity</span>
                <span>₡ @i.SubtotalCrc.ToString("N0")</span>
            </div>
        }

        <a class="btn-whatsapp"
           href="@ViewBag.WhatsappUrl"
           target="_blank">
            📲 Enviar pedido por WhatsApp
        </a>

        <p class="success-foot">
            Te contactaremos para coordinar pago y entrega.
        </p>

    </div>
</div>




