@{
    ViewData["Title"] = "Pedido confirmado";
}

<section class="custom-success">

    <div class="success-card">

        <div class="success-icon">✓</div>

        <h1>Pedido confirmado</h1>

        <p class="success-text">
            Tu pedido fue recibido correctamente.
            Estamos procesándolo y te notificaremos cualquier actualización.
        </p>

        <div class="success-info">
            <p>
                <strong>Número de pedido:</strong>
                <span>#@ViewBag.OrderId</span>
            </p>

            <p><strong>¿Qué sigue ahora?</strong></p>
            <ul>
                <li>Procesamos tu pedido</li>
                <li>Verificamos el pago y el stock</li>
                <li>Coordinamos la entrega</li>
            </ul>
        </div>

        <div class="success-actions">
            <a asp-controller="Account"
               asp-action="OrderDetails"
               asp-route-id="@ViewBag.OrderId"
               class="btn-saint">
                Ver detalle del pedido
            </a>

            <a asp-controller="Shop"
               asp-action="Index"
               class="btn-saint-outline">
                Seguir comprando
            </a>
        </div>

    </div>

</section>
