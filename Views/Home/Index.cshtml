@{
    ViewData["Title"] = "Saint Hub";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-animations.css" asp-append-version="true" />

}

<!-- HERO -->
<section class="home-hero" style="background-image:url('/img/home/hero.jpg')">
    <div class="home-hero-overlay"></div>

    <div class="home-hero-content">

        <h1>SAINT HUB</h1>
        <p>Sneakers & Culture</p>

        <a href="#purchase-modes" class="btn-saint scroll-soft">
            Explorar tienda
        </a>


    </div>
</section>
<section class="purchase-modes" id="purchase-modes">


    <!-- EN STOCK -->
    <a asp-controller="Category"
       asp-action="Index"
       asp-route-fulfillment="1"
       class="mode-card reveal reveal-up"
       style="background-image:url('/img/home/stock.jpg')">

        <div class="mode-overlay"></div>

        <div class="mode-content">
            <h3>En stock</h3>
            <p>Productos disponibles para envío o retiro inmediato.</p>
        </div>
    </a>

    <!-- POR ENCARGO -->
    <a asp-controller="Category"
       asp-action="Index"
       asp-route-fulfillment="2"
       class="mode-card reveal reveal-up"
       style="background-image:url('/img/home/on-demand.jpg')">

        <div class="mode-overlay"></div>

        <div class="mode-content">
            <h3>Por encargo</h3>
            <p>Traemos piezas exclusivas bajo pedido.</p>
        </div>
    </a>


    <!-- CUSTOM ORDER (NO SE TOCA) -->
    <a asp-controller="CustomOrder"
       asp-action="Index"
       class="mode-card reveal reveal-up"
       style="background-image:url('/img/home/custom.jpg');
              transition-delay:.35s">

        <div class="mode-overlay"></div>

        <div class="mode-content">
            <h3>Pedido personalizado</h3>
            <p>Buscamos lo que querés, a tu medida.</p>
            
        </div>
    </a>

</section>



<section class="home-how">

    <div class="how-header reveal">
        <small>Proceso</small>
        <h2>Cómo funciona Saint Hub</h2>
        <p>
            Seleccionamos piezas con criterio.
            Te acompañamos durante todo el proceso.
        </p>
    </div>

    <div class="how-steps">

      

