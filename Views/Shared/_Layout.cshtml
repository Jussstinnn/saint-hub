            <!-- MOBILE MENU -->
            <nav class="mobile-menu" id="mobileMenu">
                <div class="mobile-menu-header">
                    <span>Menú</span>
                    <button id="closeMenu">&times;</button>
                </div>

                @if (isLogged)
                {
                    <span style="padding:.6rem 1rem; color:var(--text-muted);">
                        👤 @firstName
                    </span>

                    <a asp-controller="Account" asp-action="Dashboard">Mi cuenta</a>

                    <a asp-controller="Account" asp-action="Logout">Cerrar sesión</a>
                }

                else
