        <!-- =========================
             HEADER (NAVBAR)
        ========================= -->
        <header class="saint-header">

            <!-- TOPBAR -->
            <div class="saint-topbar">

                <!-- HAMBURGER -->
                <button class="nav-hamburger" id="openMenu" aria-label="Abrir menú">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <!-- LOGO -->
                <a asp-controller="Home" asp-action="Index" class="saint-logo">
                    <img src="~/img/branding/logo-white.png" alt="Saint Hub" />
                </a>

                <!-- CART MOBILE -->
                <a asp-controller="Cart" asp-action="Index" class="nav-cart">
                    <i class="bi bi-bag"></i>
                    <span class="cart-count">@cartCount</span>

                </a>
               
                

                <!-- LEFT -->
                <div class="nav-left">
                    <div class="saint-social">
                        <a href="https://www.instagram.com/saint_hubcr/" target="_blank" class="social-icon">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="https://wa.me/50671270397" target="_blank" class="social-icon">
                            <i class="bi bi-whatsapp"></i>
                        </a>
                    </div>

                    <form asp-controller="Shop"
                          asp-action="Index"
                          method="get"
                          class="saint-search-form desktop-search">

                        <div class="saint-search-wrapper">
                            <i class="bi bi-search saint-search-icon"></i>

                            <input class="saint-search"
                                   name="q"
                                   placeholder="Buscar sneakers, marcas, modelos…" />
                        </div>
                    </form>

                </div>

                <!-- RIGHT -->
                <div class="top-right">

                    @if (isLogged)
                    {
                        <a asp-controller="Account"
                           asp-action="Dashboard"
                           class="nav-btn outline">
                            <i class="bi bi-person"></i>
                            <span>@firstName</span>
                        </a>


                        <a asp-controller="Account"
                           asp-action="Logout"
                           class="nav-btn outline">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Salir</span>
                        </a>
                    }

                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="nav-btn outline">
                            <i class="bi bi-person"></i>
                            <span>Inicia sesión</span>
                        </a>

                        <a asp-controller="Account" asp-action="Register" class="nav-btn outline">
                            <i class="bi bi-person-plus"></i>
                            <span>Regístrate</span>
                        </a>
                    }

                    <a asp-controller="Cart" asp-action="Index" class="nav-btn outline">
                        <i class="bi bi-bag"></i>
                        <span>Carrito</span>
                        <span class="cart-count">@cartCount</span>

                    </a>
                </div>
            </div>

