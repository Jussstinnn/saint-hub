                           asp-route-fulfillment="2">
                            Por encargo
                        </a>
                    </div>
                </div>

                <!-- PANTALONES -->
                <div class="mobile-category">
                    <button class="mobile-category-toggle">
                        Pantalones
                        <span class="chevron">›</span>
                    </button>

                    <div class="mobile-submenu">
                        <a asp-controller="Category"
                           asp-action="Index"
