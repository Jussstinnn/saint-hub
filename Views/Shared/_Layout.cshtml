                            En stock
                        </a>

                        <a asp-controller="Category"
                           asp-action="Index"
                           asp-route-id="6"
                           asp-route-fulfillment="2">
                            Por encargo
                        </a>
                    </div>
                </div>

            </nav>

        </header>

        <!-- MOBILE SEARCH -->
        <!-- MOBILE SEARCH -->
        <form asp-controller="Shop"
              asp-action="Index"
              method="get"
              class="mobile-search">

            <i class="bi bi-search search-icon"></i>

            <input class="saint-search mobile-search-input"
                   type="search"
                   name="q"
                   placeholder="Buscar sneakers, marcas, modelos…" />
        </form>



    }

    @if (isAdmin)
    {
        <div class="admin-shell">
            <aside class="admin-sidebar">
                <div class="admin-logo">
                    <img src="~/img/branding/logo-white.png" />
                </div>

                <nav class="admin-nav">
                    <a asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                    <a asp-controller="AdminProducts" asp-action="Index">Productos</a>
                    <a asp-controller="AdminOrders" asp-action="Index">Pedidos</a>
                    <a asp-controller="AdminCustomRequests" asp-action="Index">Clientes</a>
                    <a asp-controller="Account" asp-action="Logout">Salir</a>
                </nav>
            </aside>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main class="site-shell">
            @RenderBody()
        </main>
    }

    @if (!isAdmin)
    {
        <footer>
            © @DateTime.Now.Year · Saint Hub · Sneakers & Culture
        </footer>
    }
    <script>
        function updateCartCount(count) {
            document.querySelectorAll('.cart-count').forEach(el => {
                if (count > 0) {
                    el.textContent = count;
                    el.style.display = 'inline-flex';
                } else {
                    el.style.display = 'none';
                }
            });
        }
    </script>


    <script>
        const openBtn = document.getElementById("openMenu");
        const closeBtn = document.getElementById("closeMenu");
        const menu = document.getElementById("mobileMenu");

        if (openBtn && closeBtn && menu) {
            openBtn.addEventListener("click", () => {
                menu.classList.add("open");
                document.body.style.overflow = "hidden";
            });

            closeBtn.addEventListener("click", () => {
                menu.classList.remove("open");
                document.body.style.overflow = "";
            });
        }
    </script>
    <script>
        document.querySelectorAll('.mobile-category-toggle').forEach(toggle => {
            toggle.addEventListener('click', () => {
                const parent = toggle.closest('.mobile-category');

                // Cerrar otros (opcional pero recomendado)
                document.querySelectorAll('.mobile-category').forEach(cat => {
                    if (cat !== parent) cat.classList.remove('open');
                });

                parent.classList.toggle('open');
            });
        });
    </script>

</body>
</html>
